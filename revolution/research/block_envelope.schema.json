{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jsontube.org/schemas/revolution/block-envelope-v0.2.json",
  "title": "Revolution block envelope v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "block_id",
    "claim",
    "active_rivals",
    "nulls",
    "strongest_counterexample",
    "falsifier",
    "return_if",
    "compression_losses",
    "provenance",
    "decision"
  ],
  "properties": {
    "schema_version": {"const": "0.2"},
    "block_id": {"type": "string", "pattern": "^REV:BLOCK:[A-Z0-9._-]+$"},
    "claim": {"type": "string", "minLength": 1},
    "active_rivals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "prediction", "falsifier", "support", "state", "return_if"],
        "properties": {
          "id": {"type": "string", "pattern": "^REV:RIVAL:[A-Z0-9._-]+$"},
          "prediction": {"type": "string", "minLength": 1},
          "falsifier": {"type": "string", "minLength": 1},
          "support": {"type": "array", "items": {"type": "string"}},
          "state": {"enum": ["active", "dormant", "retired"]},
          "return_if": {"type": "string", "minLength": 1}
        }
      }
    },
    "nulls": {"type": "array", "items": {"type": "string"}},
    "strongest_counterexample": {"type": "string", "minLength": 1},
    "falsifier": {"type": "string", "minLength": 1},
    "return_if": {"type": "string", "minLength": 1},
    "compression_losses": {"type": "array", "items": {"type": "string"}},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_ids", "compiler_id", "compiled_at", "source_hashes"],
      "properties": {
        "source_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "compiler_id": {"type": "string", "minLength": 1},
        "compiled_at": {"type": "string", "format": "date-time"},
        "source_hashes": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "selected_rival_id", "reason"],
      "properties": {
        "state": {"enum": ["selected", "synthesized", "bounded_uncertainty", "insufficient_signal", "confusion_stop"]},
        "selected_rival_id": {"type": ["string", "null"]},
        "reason": {"type": "string", "minLength": 1}
      }
    }
  }
}
