{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jsontube.org/schemas/revolution/run-result-v0.2.json",
  "title": "Revolution research run result v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "protocol_id",
    "lane_id",
    "arm_id",
    "provider",
    "model",
    "model_fingerprint",
    "system_prompt_hash",
    "request_hash",
    "context_hash",
    "temperature",
    "top_p",
    "max_tokens",
    "seed",
    "request_time",
    "request_id",
    "tool_access_hash",
    "tool_trace_hash",
    "status",
    "exclusion_reason",
    "denominator_included",
    "output_hash",
    "artifact_receipt",
    "null_disposition"
  ],
  "properties": {
    "schema_version": {"const": "0.2"},
    "run_id": {"type": "string", "pattern": "^REV:RUN:[A-Z0-9._-]+$"},
    "protocol_id": {"type": "string", "pattern": "^REV:EX-[0-9]{3}$"},
    "lane_id": {"type": ["string", "null"]},
    "arm_id": {"type": "string", "minLength": 1},
    "provider": {"type": "string", "minLength": 1},
    "model": {"type": "string", "minLength": 1},
    "model_fingerprint": {"type": ["string", "null"]},
    "system_prompt_hash": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "request_hash": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "context_hash": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "temperature": {"type": ["number", "null"]},
    "top_p": {"type": ["number", "null"]},
    "max_tokens": {"type": ["integer", "null"]},
    "seed": {"type": ["integer", "string", "null"]},
    "request_time": {"type": "string", "format": "date-time"},
    "request_id": {"type": ["string", "null"]},
    "tool_access_hash": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "tool_trace_hash": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "status": {"enum": ["completed", "refusal", "missing", "technical_failure", "provider_contaminated", "failed_manipulation", "confusion_stop"]},
    "exclusion_reason": {"type": ["string", "null"]},
    "denominator_included": {"const": true},
    "output_hash": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "artifact_receipt": {"type": ["string", "null"]},
    "null_disposition": {"enum": ["not_null", "examined_no_effect", "failed_manipulation", "uninterpretable", "refusal", "missing", "excluded_with_reason", "never_sampled"]}
  }
}
